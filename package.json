{
  "name": "urai-storytime",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:preflight && playwright test",
    "test:e2e:preflight": "node scripts/check-playwright-config.mjs",
    "test:e2e:diagnostics": "node scripts/playwright-diagnostics.mjs",
    "test:e2e:install": "npm run test:e2e:diagnostics && playwright install chromium",
    "test:e2e:install-with-deps": "npm run test:e2e:diagnostics && playwright install --with-deps chromium",
    "test:smoke": "npm run test:e2e:preflight && playwright test tests/e2e/storytime.spec.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "firebase:emulators": "firebase emulators:start",
    "deploy:preflight": "node scripts/check-deploy-readiness.mjs",
    "deploy:staging": "URAI_DEPLOY_TARGET=staging npm run deploy",
    "deploy": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build && npm run deploy:preflight && firebase deploy"
  },
  "dependencies": {
    "firebase": "^10.14.1",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.1.1",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
