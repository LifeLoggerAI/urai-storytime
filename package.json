{
  "name": "urai-storytime",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/unit/*.test.mjs tests/e2e/*.test.mjs",
    "test:smoke": "node tests/e2e/smoke.test.mjs",
    "test:e2e": "node tests/e2e/smoke.test.mjs",
    "firebase:emulators": "firebase emulators:start",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy": "npm run build && firebase deploy",
    "format": "node scripts/format-check.mjs"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
