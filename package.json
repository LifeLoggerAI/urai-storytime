{
  "name": "urai-storytime",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e/storytime.spec.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "firebase:emulators": "firebase emulators:start",
    "deploy": "npm run build && firebase deploy"
  },
  "dependencies": {
    "firebase": "^10.14.1",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.1.1",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.12.0",
    "eslint-config-next": "^14.2.25",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
