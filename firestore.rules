
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is the owner of a given family.
    // It reads the `ownerUid` from the family document.
    function isFamilyOwner(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data.ownerUid == request.auth.uid;
    }

    // Families Collection:
    // - Users can read a family document ONLY if they are the owner.
    // - Users can create a family document.
    // - No updates or deletes are allowed for V1 to ensure data integrity.
    match /families/{familyId} {
      allow read: if isFamilyOwner(familyId);
      allow create: if request.auth != null;
      allow update, delete: if false;

      // Children Sub-collection:
      // - Users can read and create children ONLY for a family they own.
      // - No updates or deletes for V1.
      match /children/{childId} {
        allow read, create: if isFamilyOwner(familyId);
        allow update, delete: if false;
      }

      // Stories Sub-collection:
      // - Users can read and create stories ONLY for a family they own.
      // - No updates or deletes for V1.
      match /stories/{storyId} {
        allow read, create: if isFamilyOwner(familyId);
        allow update, delete: if false;
      }
    }
  }
}
