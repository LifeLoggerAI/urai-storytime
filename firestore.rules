rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for authentication and ownership
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the requesting user is the owner of the family document.
    function isFamilyOwner(familyId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/families/$(familyId)).data.ownerUid;
    }

    // Rules for the 'families' collection
    match /families/{familyId} {

      // A user can only read their own family document.
      allow read: if isFamilyOwner(familyId);

      // A new family document can be created if the user is authenticated
      // and sets themselves as the owner.
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;

      // The owner can update or delete their family document.
      allow update, delete: if isFamilyOwner(familyId);

      // Rules for the 'children' subcollection
      match /children/{childId} {
        // Only the family owner can manage child documents.
        allow read, write: if isFamilyOwner(familyId);
      }

      // Rules for the 'stories' subcollection
      match /stories/{storyId} {
        // Only the family owner can read stories.
        allow read: if isFamilyOwner(familyId);

        // Stories are created by a backend function, not the client.
        allow create: if false;

        // Clients can only update the 'isRead' status of a story.
        allow update: if isFamilyOwner(familyId)
                      && request.resource.data.diff(resource.data).changedKeys()
                         .hasOnly(["isRead"]);

        // The family owner can delete stories.
        allow delete: if isFamilyOwner(familyId);
      }

      // Rules for the 'settings' subcollection
      match /settings/{settingsDoc} {
        // Only the family owner can manage their settings.
        allow read, write: if isFamilyOwner(familyId);
      }
    }
  }
}