
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // By default, deny all reads and writes to the entire bucket.
    // The application's security model relies on Cloud Functions generating
    // short-lived signed URLs for authorized users to access specific assets.
    // This prevents any possibility of unauthorized direct access, listing, or modification
    // of stored files via the client-side SDKs.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
