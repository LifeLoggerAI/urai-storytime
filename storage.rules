rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function familyDoc(familyId) {
      return firestore.get(/databases/(default)/documents/families/$(familyId));
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/families/$(familyId))
        && request.auth.uid in familyDoc(familyId).data.memberUserIds;
    }

    match /families/{familyId}/{allPaths=**} {
      allow read: if isFamilyMember(familyId) || isAdmin();
      allow write: if isFamilyMember(familyId) || isAdmin();
    }

    match /creatorSubmissions/{creatorId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == creatorId || request.auth.token.admin == true || request.auth.token.moderator == true);
      allow write: if signedIn() && (request.auth.uid == creatorId || request.auth.token.admin == true);
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
